{
  "headers": [
    {
      "source": "/(.*).(js|css|svg|json)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).(png|jpg|jpeg|webp|avif|gif)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "https://www.usaghostwriter.com/:path*",
      "destination": "https://usaghostwriter.com/:path*",
      "permanent": true
    }
  ]
}
